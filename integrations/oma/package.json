{
  "name": "toolgovern-integration-oma",
  "version": "0.1.1",
  "private": false,
  "description": "Adapter shapes (per-tool governedTool and dispatcher-style governedExecutor) for wiring toolgovern into an open-multi-agent-style tool-executor call site.",
  "homepage": "https://github.com/RudrenduPaul/toolgovern#readme",
  "bugs": {
    "url": "https://github.com/RudrenduPaul/toolgovern/issues"
  },
  "keywords": [
    "open-multi-agent",
    "ai-agents",
    "agent-security",
    "runtime-governance",
    "tool-calling",
    "toolgovern"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RudrenduPaul/toolgovern.git",
    "directory": "integrations/oma"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit --strict",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "toolgovern": "0.1.2"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
