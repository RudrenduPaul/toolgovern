{
  "name": "toolgovern-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Runtime governance layer for AI agent tool calls",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "integrations/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit": "npm audit --audit-level=high",
    "bench:detection-rate": "node --experimental-strip-types benchmarks/detection-rate.ts",
    "bench:latency": "node --experimental-strip-types benchmarks/latency.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.10"
  }
}
