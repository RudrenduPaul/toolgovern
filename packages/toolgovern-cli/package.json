{
  "name": "toolgovern-cli",
  "version": "0.1.6",
  "description": "CLI for toolgovern -- validate policy files, audit local gate traces, and scaffold framework integration boilerplate, with a --json output mode for programmatic/agent use.",
  "homepage": "https://github.com/RudrenduPaul/toolgovern#readme",
  "bugs": {
    "url": "https://github.com/RudrenduPaul/toolgovern/issues"
  },
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "toolgovern-cli": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RudrenduPaul/toolgovern.git",
    "directory": "packages/toolgovern-cli"
  },
  "keywords": [
    "ai-agents",
    "agent-security",
    "runtime-governance",
    "tool-calling",
    "cli",
    "policy-validation",
    "audit-trail"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit --strict",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "toolgovern": "0.1.3",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
